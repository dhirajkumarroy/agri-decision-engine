# ─── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://localhost:27017/ai_crop_advisor

# ─── FastAPI ML Backend ────────────────────────────────────────
ML_BACKEND_URL=http://localhost:8000

# ─── MQTT / IoT ────────────────────────────────────────────────
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_SENSOR_TOPIC=farm/sensor
MQTT_ACTUATOR_TOPIC=farm/actuator
MQTT_PUBLISH_RETRIES=3
MQTT_CLIENT_ID_PREFIX=ai-crop-advisor
SIMULATOR_INTERVAL_MS=5000

# ─── OpenWeatherMap ───────────────────────────────────────────
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ─── JWT Auth ─────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── Email (Nodemailer / SMTP) ────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM="AI Crop Advisor <your_email@gmail.com>"
EMAIL_TO=support@aicropadvisor.com

# ─── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
ML_RATE_LIMIT_MAX=20

# ─── Cache TTL (seconds) ──────────────────────────────────────
WEATHER_CACHE_TTL=600
CROP_INFO_CACHE_TTL=86400
FORECAST_CACHE_TTL=1800

# ─── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ─── AI Provider ──────────────────────────────────────────────
AI_PROVIDER=ollama
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3

# Optional cloud providers
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-1
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
